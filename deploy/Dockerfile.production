FROM node:22.20.0-bookworm-slim AS node-runtime

FROM python:3.11-slim

WORKDIR /app

RUN echo "deb http://mirrors.aliyun.com/debian/ bookworm main contrib non-free non-free-firmware" > /etc/apt/sources.list && \
    echo "deb http://mirrors.aliyun.com/debian/ bookworm-updates main contrib non-free non-free-firmware" >> /etc/apt/sources.list && \
    echo "deb http://mirrors.aliyun.com/debian-security/ bookworm-security main contrib non-free non-free-firmware" >> /etc/apt/sources.list

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    UV_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/ \
    UV_LINK_MODE=copy

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

COPY --from=node-runtime /usr/local/bin/node /usr/local/bin/node
COPY --from=node-runtime /usr/local/lib/node_modules /usr/local/lib/node_modules

RUN ln -s /usr/local/lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm && \
    ln -s /usr/local/lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx

RUN pip install --no-cache-dir \
    uv \
    gunicorn \
    flask \
    flask-cors \
    anthropic \
    requests \
    reportlab \
    pillow \
    jdcloud-sdk \
    "psycopg[binary]" \
    boto3 \
    -i https://mirrors.aliyun.com/pypi/simple/

COPY . /app

RUN leaked_sensitive_files="$(find /app -type f \( -name '.env' -o -name '.env.*' -o -name '*.env' -o -name '*.local.yml' -o -name '*.local.yaml' \) ! -path '/app/web/.env.example' -print)" \
    && if [ -n "$leaked_sensitive_files" ]; then \
      echo "Sensitive local config files must not be baked into the image:" >&2; \
      printf '%s\n' "$leaked_sensitive_files" >&2; \
      exit 1; \
    fi

RUN node -v && \
    npm -v && \
    python3 -c "from web import server; values = server._read_admin_site_config_values(server.get_admin_site_config_file_path(), strict=True); assert values.get('researchTips') and values.get('colors', {}).get('primary'), 'site-config.js did not parse into runtime values'"

RUN mkdir -p /app/data /app/output /app/artifacts

RUN uv run scripts/convert_doc.py --help >/dev/null || true

EXPOSE 5002

CMD ["sh", "-c", "python3 scripts/prestart_web.py && exec gunicorn -c web/gunicorn.conf.py web.wsgi:app"]
